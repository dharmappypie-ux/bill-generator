{
  "name": "bill-generator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev -p 4040",
    "build": "opennextjs-cloudflare build",
    "build:next": "next build",
    "start": "next start -p 4040",
    "lint": "next lint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply bill-generator-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply bill-generator-db --remote"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.3.0",
    "bcryptjs": "^2.4.3",
    "html2canvas": "^1.4.1",
    "jose": "^5.9.6",
    "jspdf": "^2.5.2",
    "next": "^15.1.6",
    "nodemailer": "^6.9.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250321.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.12",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "wrangler": "^4.20.0"
  }
}
