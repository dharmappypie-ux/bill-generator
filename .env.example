# ----- Core -----
# Public site URL (used for OAuth redirects, email links, Stripe redirects)
APP_URL="http://localhost:4040"

# JWT signing secret for session cookies. Generate: openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"

# ----- Database (SQLite by default; swap to a Postgres URL for prod) -----
DATABASE_URL="file:./dev.db"

# ----- Email (nodemailer SMTP) -----
# Leave blank in dev: emails (incl. OTP codes) are written to ./.mailbox and logged to the console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Bill Generator <no-reply@billgenerator.local>"

# ----- Google OAuth (optional) -----
# Authorized redirect URI: {APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ----- Stripe (optional; test keys) -----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Price IDs for the three plans (create them in Stripe, INR). Falls back to inline price_data if blank.
STRIPE_PRICE_QUARTERLY=""
STRIPE_PRICE_YEARLY=""
STRIPE_PRICE_LIFETIME=""
